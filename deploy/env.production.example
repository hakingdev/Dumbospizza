# Канонический публичный адрес сайта (с www). Используется для canonical, og:url,
# sitemap, robots, structured data и абсолютных ссылок. apex dumbospizza.de
# редиректится на www (см. middleware.ts).
NEXT_PUBLIC_SITE_URL=https://www.dumbospizza.de
NEXTAUTH_URL=https://www.dumbospizza.de
NEXTAUTH_SECRET=change_me
# HMAC-секрет для токенов доступа к заказу/счёту (openssl rand -hex 32).
# Не задан → падает на NEXTAUTH_SECRET. Одинаковый на всех инстансах.
ORDER_ACCESS_SECRET=change_me
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

SEED_SECRET_KEY=production_seed_key

